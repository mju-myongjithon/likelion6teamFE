# Development: Vite proxies both /api and /ws-chat to this backend.
VITE_DEV_PROXY_TARGET=http://localhost:8080

# Leave unset for the supported same-origin setup:
# - development: expose the Vite server with one ngrok HTTPS/WSS URL
# - production: Nginx serves dist and proxies /api plus /ws-chat
# VITE_CHAT_SOCKET_URL=wss://example.com/ws-chat
