        "selector": "JSXOpeningElement[name.name='TestimonialCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|role|avatarSrc|avatarTone|rating|children|style|key|ref|className|style|children)$/]",
        "message": "<TestimonialCard> doesn't accept that prop. Declared props: name, role, avatarSrc, avatarTone, rating, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TestimonialCard'] > JSXAttribute[name.name='avatarTone'] > Literal[value!=/^(?:neutral|orange|pink|violet|emerald)$/]",
        "message": "<TestimonialCard> avatarTone must be one of 'neutral' | 'orange' | 'pink' | 'violet' | 'emerald'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Textarea'] > JSXAttribute > JSXIdentifier[name!=/^(?:invalid|disabled|style|key|ref|className|style|children)$/]",
        "message": "<Textarea> doesn't accept that prop. Declared props: invalid, disabled, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TopNav'] > JSXAttribute > JSXIdentifier[name!=/^(?:brand|links|activeLink|right|style|key|ref|className|style|children)$/]",
        "message": "<TopNav> doesn't accept that prop. Declared props: brand, links, activeLink, right, style."
      }
    ]
