        "selector": "JSXOpeningElement[name.name='StepperStep'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|description|status|key|ref|className|style|children)$/]",
        "message": "<StepperStep> doesn't accept that prop. Declared props: title, description, status."
