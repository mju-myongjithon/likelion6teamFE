{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/actions/**",
              "components/cards/**",
              "components/chat/**",
              "components/display/**",
              "components/feedback/**",
              "components/forms/**",
              "components/foundations/**",
              "components/navigation/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Geist|Inter|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Geist, Inter, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|name|size|tone|style|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: src, name, size, tone, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|orange|pink|violet|emerald)$/]",
        "message": "<Avatar> tone must be one of 'neutral' | 'orange' | 'pink' | 'violet' | 'emerald'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|children|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|orange|pink|violet|emerald|success|warning|error)$/]",
        "message": "<Badge> tone must be one of 'neutral' | 'orange' | 'pink' | 'violet' | 'emerald' | 'success' | 'warning' | 'error'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|disabled|fullWidth|iconLeft|iconRight|children|style|onClick|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, disabled, fullWidth, iconLeft, iconRight, children, style, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CalendarEvent'] > JSXAttribute > JSXIdentifier[name!=/^(?:day|label|tone|key|ref|className|style|children)$/]",
        "message": "<CalendarEvent> doesn't accept that prop. Declared props: day, label, tone."
      },
      {
        "selector": "JSXOpeningElement[name.name='CalendarEvent'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:default|accent)$/]",
        "message": "<CalendarEvent> tone must be one of 'default' | 'accent'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Callout'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|marker|children|style|key|ref|className|style|children)$/]",
        "message": "<Callout> doesn't accept that prop. Declared props: tone, marker, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Callout'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:info|danger)$/]",
        "message": "<Callout> tone must be one of 'info' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:surface|padding|radius|shadow|children|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: surface, padding, radius, shadow, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='surface'] > Literal[value!=/^(?:card|outline|soft|dark)$/]",
        "message": "<Card> surface must be one of 'card' | 'outline' | 'soft' | 'dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='radius'] > Literal[value!=/^(?:md|lg|xl)$/]",
        "message": "<Card> radius must be one of 'md' | 'lg' | 'xl'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChatMessage'] > JSXAttribute > JSXIdentifier[name!=/^(?:mine|sender|senderTone|time|hideAvatar|children|style|key|ref|className|style|children)$/]",
        "message": "<ChatMessage> doesn't accept that prop. Declared props: mine, sender, senderTone, time, hideAvatar, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChatThreadItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|preview|time|unread|avatarTone|memberCount|active|onClick|style|key|ref|className|style|children)$/]",
        "message": "<ChatThreadItem> doesn't accept that prop. Declared props: name, preview, time, unread, avatarTone, memberCount, active, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute > JSXIdentifier[name!=/^(?:active|variant|onClick|children|style|key|ref|className|style|children)$/]",
        "message": "<Chip> doesn't accept that prop. Declared props: active, variant, onClick, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|add)$/]",
        "message": "<Chip> variant must be one of 'default' | 'add'."
      },
      {
        "selector": "JSXOpeningElement[name.name='EventCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|month|day|time|venue|tag|tagTone|matchScore|attendance|onClick|style|key|ref|className|style|children)$/]",
        "message": "<EventCard> doesn't accept that prop. Declared props: title, month, day, time, venue, tag, tagTone, matchScore, attendance, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='FeatureCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|title|children|style|key|ref|className|style|children)$/]",
        "message": "<FeatureCard> doesn't accept that prop. Declared props: icon, title, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Field'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|labelAside|children|style|key|ref|className|style|children)$/]",
        "message": "<Field> doesn't accept that prop. Declared props: label, hint, labelAside, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|strokeWidth|color|style|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, strokeWidth, color, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|size|variant|disabled|style|onClick|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: children, size, variant, disabled, style, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:outline|ghost|solid)$/]",
        "message": "<IconButton> variant must be one of 'outline' | 'ghost' | 'solid'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:iconLeft|invalid|disabled|placeholder|value|type|onChange|style|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: iconLeft, invalid, disabled, placeholder, value, type, onChange, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='MeetupCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|category|categoryTone|when|where|host|hostTone|members|capacity|matchScore|image|style|key|ref|className|style|children)$/]",
        "message": "<MeetupCard> doesn't accept that prop. Declared props: title, category, categoryTone, when, where, host, hostTone, members, capacity, matchScore, image, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='MeetupCard'] > JSXAttribute[name.name='categoryTone'] > Literal[value!=/^(?:neutral|orange|pink|violet|emerald)$/]",
        "message": "<MeetupCard> categoryTone must be one of 'neutral' | 'orange' | 'pink' | 'violet' | 'emerald'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MeetupCard'] > JSXAttribute[name.name='hostTone'] > Literal[value!=/^(?:neutral|orange|pink|violet|emerald)$/]",
        "message": "<MeetupCard> hostTone must be one of 'neutral' | 'orange' | 'pink' | 'violet' | 'emerald'."
      },
      {
        "selector": "JSXOpeningElement[name.name='NavPillItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|key|ref|className|style|children)$/]",
        "message": "<NavPillItem> doesn't accept that prop. Declared props: value, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='PlaceVoteOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|label|sub|votes|key|ref|className|style|children)$/]",
        "message": "<PlaceVoteOption> doesn't accept that prop. Declared props: id, label, sub, votes."
      },
      {
        "selector": "JSXOpeningElement[name.name='PricingTierCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|price|period|description|features|cta|featured|style|key|ref|className|style|children)$/]",
        "message": "<PricingTierCard> doesn't accept that prop. Declared props: name, price, period, description, features, cta, featured, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProfilePopoverEvent'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|when|tone|key|ref|className|style|children)$/]",
        "message": "<ProfilePopoverEvent> doesn't accept that prop. Declared props: title, when, tone."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:step|total|value|showLabel|label|style|key|ref|className|style|children)$/]",
        "message": "<ProgressBar> doesn't accept that prop. Declared props: step, total, value, showLabel, label, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='RatingStars'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|max|size|showValue|style|key|ref|className|style|children)$/]",
        "message": "<RatingStars> doesn't accept that prop. Declared props: value, max, size, showValue, style."
      },
